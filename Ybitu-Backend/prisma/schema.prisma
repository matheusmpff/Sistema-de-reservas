// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Tabelas das pessoas, crianças, adultos e users e suas relações. Usei id ao invés do email para que se 
// a pessoa queira mudar o email não tenha problema nas relações entre as Tabelas

model Pessoa {
  // Colunas da tabela Pessoa
  id           Int            @id @default(autoincrement())
  nome         String
  dataNasc     DateTime
  sexo         String
  // Relações com as demais tabelas
  adulto       Adulto? // Relação 1 - 0..1
  crianca      Crianca? // Relação 1 - 0..1
  acompanhante Acompanhante[] // Relação 1 - N
}
  
model Adulto {
  // Colunas da tabela Adulto
  idPessoa Int    @id
  email    String @unique
  telefone String
  // Relação com as demais tabelas
  pessoa   Pessoa    @relation(fields: [idPessoa], references: [id])
  user     User? // Relação 1 - 0..1 (Um adulto pode ser um user ou não)
  criancas Crianca[] // Relação 1 - N (Um adulto pode ser responsável por mais de 1 criança)
}

model Crianca {
  // Colunas tabela Criança
  idPessoa Int @id
  idResp   Int
  // Relação com as demais tabelas
  responsavel Adulto @relation(fields: [idResp], references: [idPessoa])
  pessoa      Pessoa @relation(fields: [idPessoa], references: [id])
}

model User {
  // Colunas tabela user
  idAdulto Int    @id
  senha    String
  // Relação com as demais tabelas
  adulto Adulto @relation(fields: [idAdulto], references: [idPessoa])
  reservas Reserva[]
}

// Tabela de reserva e suas relações as tabelas Feedbackuser e ReservaQuartos não estão completas ainda com
// todos os campos necessários para elas. Fiz apenas a relação delas com a tabela de reservas

enum TipoStatus {
  IN
  OUT
  EM_ANALISE
  PAGO
  CANCELADO
}

model Reserva {
  // Campos da tabela reserva
  idUser      Int
  dataReserva DateTime
  checkIn     DateTime
  checkOut    DateTime
  numPessoas  Int
  status      TipoStatus
  valor       Int
  //Relações com as outras tabelas
  acompanhante   Acompanhante[] // Relação 1-N
  feedbackUser   FeedbackUser? // Relação 1-0..1
  // Relação 1-0..1(Teria que sempre que criar uma reserva criar junto o reservaQuartos 
  //para garantir a relação 1-1 desejada)
  reservaQuartos ReservaQuartos?
  user User @relation(fields: [idUser],references: [idAdulto])

  @@id([idUser, dataReserva]) // Identificador da Reserva é o usuário e a data da reserva
}

model Acompanhante {
  // Colunas da tabela Acompanhante
  reservaUser Int
  reservaData DateTime
  idPessoa    Int
  @@id([reservaUser, reservaData, idPessoa]) // força que esse trio seja unico para evitar duplicação de acompanhante
  // Relações com as demais tabelas
  feedback FeedbackAcompanhante?
  pessoa  Pessoa  @relation(fields: [idPessoa], references: [id])
  reserva Reserva @relation(fields: [reservaUser, reservaData], references: [idUser, dataReserva])
}

model FeedbackUser {
  // Colunas da tabela
  reservaUser Int
  reservaData DateTime
  comentario String
  fotos String[]
  @@id([reservaUser, reservaData])// ID é o usuário e a data de reserva
  // Relação com as demais tabelas
  reserva Reserva @relation(fields: [reservaUser, reservaData], references: [idUser, dataReserva])
}

model FeedbackAcompanhante {
  // Colunas da tabela
  reservaUser Int
  reservaData DateTime
  idPessoa Int
  comentario String
  fotos String[]
  @@id([reservaUser, reservaData, idPessoa])// ID é o usuário e a data de reserva
  // Relação com as demais tabelas
  acompanhante Acompanhante @relation(fields: [reservaUser,reservaData,idPessoa], references: [reservaUser,reservaData,idPessoa])
}

model ReservaQuartos {
  // Colunas da tabela
  reservaUser Int
  reservaData DateTime
  custo_frigobar Float
  multa Float
  @@id([reservaUser, reservaData])// ID é o usuário e a data da reserva
  // Relação com as demais tabelas
  Quartos Quarto[]
  reserva Reserva @relation(fields: [reservaUser, reservaData], references: [idUser, dataReserva])
}

enum QuartoStatus {
  OCUPADO
  MANUTENCAO
  DISPONIVEL
}

enum QuartoTipo {
  DUPLO
  TRIPLO
  QUADRUPLO
}

model Quarto {
  // Colunas
  numero Int @id
  tipo QuartoTipo
  capacidade Int
  status QuartoStatus 
  // Relação com as demais tabela
  reservaUser Int?
  reservaData DateTime?
  Reserva ReservaQuartos? @relation(fields: [reservaUser,reservaData],references: [reservaUser,reservaData])
}
